#!/bin/sh
# ccache wrapper for Xcode C compiler
# Used by customXcodeFlags CC= setting in .jucer files.
#
# -Xclang -fno-pch-timestamp tells clang to record a constant timestamp in the
# generated PCH so that ccache-restored PCHs aren't rejected for source-mtime
# drift between the cache write and a later cache hit. Required when ccache is
# combined with usePrecompiledHeaderFile.
if command -v ccache >/dev/null 2>&1; then
    exec ccache clang -Xclang -fno-pch-timestamp "$@"
else
    exec clang "$@"
fi
